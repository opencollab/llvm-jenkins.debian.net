#!/bin/sh
set -ex

ARCH=$(uname -m)
echo "Also start sccache to test"
mkdir -p /opt/sccache
cd /opt/sccache/
# This hook runs as root, but debian/rules starts the sccache server as the
# non-root pbuilder build user. Both write SCCACHE_ERROR_LOG=/opt/sccache/sccache.log,
# so the log (and dir) must be writable by both. Otherwise the root-created log is
# unwritable by the builder -> "Cannot open/write log file" -> FTBFS at configure.
# (amd64's image happens to ship a 0666 sccache.log; make every arch self-healing.)
chmod 777 /opt/sccache 2>/dev/null || true
touch /opt/sccache/sccache.log 2>/dev/null && chmod 666 /opt/sccache/sccache.log 2>/dev/null || true
# Re-download if the binary is missing, empty (a truncated/interrupted prior
# download leaves a 0-byte stub on the persistent s390x host), not runnable, or
# present-but-broken: a stale GNU/dynamic build whose ELF interpreter is gone
# runs as exit 127 "not found" despite being non-empty and +x, so the size/+x
# tests alone keep it and FTBFS. `./sccache --version` is the real liveness check
# (cheap, needs no server) -- if it can't even print its version, re-download.
if test ! -s sccache || test ! -x sccache || ! ./sccache --version >/dev/null 2>&1; then
    rm -f sccache
    # Map the system architecture to the upstream release triple.
    # mozilla/sccache ships static musl binaries (no libssl/libcrypto needed,
    # GCS support built in) for all the arches we build on.
    case "$ARCH" in
        x86_64)          triple="x86_64-unknown-linux-musl" ;;
        aarch64)         triple="aarch64-unknown-linux-musl" ;;
        i686 | i386)     triple="i686-unknown-linux-musl" ;;
        s390x)           triple="s390x-unknown-linux-musl" ;;
        *)
            echo "no sccache binary available for arch $ARCH"
            exit 0
            ;;
    esac

    # Download the latest sccache release from GitHub.
    TAG=$(wget -qO- --no-check-certificate https://api.github.com/repos/mozilla/sccache/releases/latest \
        | grep -m1 '"tag_name"' | cut -d'"' -f4)
    echo "Downloading sccache $TAG for $triple"
    time wget -O sccache.tar.gz --no-check-certificate \
        "https://github.com/mozilla/sccache/releases/download/$TAG/sccache-$TAG-$triple.tar.gz"
    tar -xzf sccache.tar.gz --strip-components=1 "sccache-$TAG-$triple/sccache"
    rm -f sccache.tar.gz

    chmod +x sccache
fi
if test "$ARCH" != "s390x"; then
    # We are in gcp, use the gcs storage
    export SCCACHE_GCS_BUCKET=apt-llvm-org-sccache
    export SCCACHE_GCS_RW_MODE=READ_WRITE
    export SCCACHE_GCS_KEY_PATH=/opt/sccache/secret-gcp-storage.json
else
    # we are on s390x, use a local cache
    mkdir -p /opt/sccache/cache/
    mkdir -p /opt/sccache/cache/preprocessor ~/.cache/sccache/
    export SCCACHE_DIR=/opt/sccache/cache/
    export SCCACHE_DIRECT=true
    chmod 777 /opt/sccache/cache/preprocessor $SCCACHE_DIR ~/.cache/sccache/
fi
export SCCACHE_VERBOSE_STATS=1
SCCACHE_LOG=sccache=debug SCCACHE_ERROR_LOG=sccache.log LD_LIBRARY_PATH=/opt/sccache/ /opt/sccache/sccache --show-stats || { exit_status=$?; true; }

if [ -n "$exit_status" ] && [ $exit_status -ne 0 ]; then
    echo "sccache failed with exit status $exit_status"
    tail -50 sccache.log
    # Perform any additional actions here, e.g., send an email, log the error, etc.
else
    echo "sccache failed with exit status $exit_status"
fi
ls -al

exit 0

# To rebuild sccache:
# on a bionic chroot
sudo mount -t proc /proc/ bionic.i386/proc
sudo mount -t proc /proc/ bionic/proc
apt install -y libssl-dev git pkg-config curl gcc libc6-dev --no-install-recommends
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
source "$HOME/.cargo/env"
git clone https://github.com/mozilla/sccache.git
cd sccache
git checkout <tag>
cargo build --release --no-default-features --features=gcs
strip target/release/sccache
cp target/release/sccache /tmp/
exit
sudo cp bionic/tmp/sccache .
